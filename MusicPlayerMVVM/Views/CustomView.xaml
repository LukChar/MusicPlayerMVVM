<UserControl x:Class="MusicPlayerMVVM.Views.CustomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="500" Background="#222222">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="180">
            <Image Source="../Resources/custom_genre_banner.jpg"
                   Opacity="0.3"
                   Stretch="UniformToFill"/>

            <Button Content="⬅" 
                    Style="{StaticResource PrimaryWideButton}" 
                    Width="30" Height="30" FontSize="11"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="10"
                    Command="{Binding BackToHomeCommand}"
                    ToolTip="Zurück zum Hauptmenü"/>

            <StackPanel VerticalAlignment="Bottom" Margin="10,0,0,15">
                <TextBlock Text="PLAYLIST" Foreground="White" FontSize="14" FontWeight="Medium"/>
                <TextBlock Text="Eigene Playlist" Foreground="White" FontSize="36" FontWeight="Medium"/>
                <TextBlock Text="Deine Lieblings-Titel" Foreground="LightGray" FontSize="12" FontWeight="Medium"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">

                <Expander VerticalAlignment="Top" Margin="0,0,10,0">
                    <Expander.Template>
                        <ControlTemplate TargetType="Expander">
                            <StackPanel>

                                <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Cursor="Hand"
                                              ToolTip="Klicke hier, um das Eingabemenü zu öffnen">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="#1DB954" 
                                                    Width="150" 
                                                    Height="40" 
                                                    CornerRadius="25">
                                                <TextBlock Text="➕ Hinzufügen" 
                                                           Foreground="White" 
                                                           FontWeight="Bold" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Margin="0,10,0,0"/>

                            </StackPanel>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsExpanded" Value="True">
                                    <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Expander.Template>

                    <Border Background="#252525" CornerRadius="10" Padding="15">
                        <StackPanel Width="250">
                            <TextBlock Text="Titel:" Foreground="LightGray" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,0,10" Padding="5" ToolTip="Name des Liedes"/>

                            <TextBlock Text="Interpret:" Foreground="LightGray" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NewArtist, UpdateSourceTrigger=PropertyChanged}" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,0,10" Padding="5" ToolTip="Name des Künstlers"/>

                            <TextBlock Text="Dateipfad (.wav):" Foreground="LightGray" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding NewFilePath, UpdateSourceTrigger=PropertyChanged}" Background="#333333" Foreground="White" BorderThickness="0" Padding="5" Margin="0,0,5,0" ToolTip="Lokaler Dateipfad"/>
                                <Button Grid.Column="1" Content="📂" Command="{Binding BrowseFileCommand}" Style="{StaticResource PrimaryWideButton}" Padding="10,0" ToolTip="Windows-Dateiexplorer öffnen"/>
                            </Grid>

                            <TextBlock Text="Dauer:" Foreground="LightGray" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NewDuration, UpdateSourceTrigger=PropertyChanged}" Background="#333333" Foreground="White" BorderThickness="0" Margin="0,0,0,15" Padding="5" ToolTip="Format MM:SS (z.B. 03:15)"/>

                            <Button Content="💾 Speichern" Command="{Binding AddSongCommand}" Style="{StaticResource PrimaryWideButton}" Padding="15,8" HorizontalAlignment="Right" ToolTip="Lied in der Datenbank speichern"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <Button Content="🗑 Löschen" 
                        Command="{Binding DeleteSongCommand}" 
                        Style="{StaticResource PrimaryWideButton}" 
                        VerticalAlignment="Top" 
                        Padding="10,5" 
                        ToolTip="Das aktuell markierte Lied endgültig löschen"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#252525" CornerRadius="10">
                <ListView ItemsSource="{Binding Songs}" SelectedItem="{Binding SelectedSong}" 
                          Background="#333333" Foreground="White" Margin="10" ToolTip="Klicke auf ein Lied, um es auszuwählen und abzuspielen">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{Binding Title}" Foreground="White" Margin="5,0"/>
                                <TextBlock Text=" - " Foreground="LightGray"/>
                                <TextBlock Text="{Binding Artist}" Foreground="LightGray" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>
    </Grid>
</UserControl>
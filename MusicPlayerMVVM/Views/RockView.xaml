<UserControl x:Class="MusicPlayerMVVM.Views.RockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="450" Background="#222222">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>
        <Grid DockPanel.Dock="Top" Height="300">
            <Image Source="../Resources/rock-music-sign-logo-29bc20.png"
                   Opacity="0.3"
                   Stretch="UniformToFill"/>

            <Button Content="⬅" 
                    Style="{StaticResource GreenWideButton}" 
                    Width="30" Height="30" FontSize="11"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="10"
                    Command="{Binding MainViewModel.NavigateHomeCommand}"/>

            <StackPanel VerticalAlignment="Bottom" Margin="8">
                <TextBlock Text="PLAYLIST" Foreground="White" FontSize="14" FontWeight="Medium"/>
                <TextBlock Text="Rock" Foreground="White" FontSize="44" FontWeight="Medium"/>
                <TextBlock Text="Feinster Rock-Mix für dich" Foreground="LightGray" FontSize="12" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <StackPanel Background="#252525" Margin="10">
            <ListView ItemsSource="{Binding Songs}" SelectedItem="{Binding SelectedSong}" Height="400" Background="#333333" Foreground="White" Margin="0,10,0,10">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding Title}" Foreground="White" Margin="5,0"/>
                            <TextBlock Text=" - " Foreground="LightGray"/>
                            <TextBlock Text="{Binding Artist}" Foreground="LightGray" Margin="5,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Style="{StaticResource GreenCircleButton}" Content="⏮" Command="{Binding PreviousSongCommand}" FontSize="18"/>
                <Button Style="{StaticResource GreenCircleButton}" Content="⏯" Command="{Binding PlayPauseCommand}" FontSize="20"/>
                <Button Style="{StaticResource GreenCircleButton}" Content="⏭" Command="{Binding NextSongCommand}" FontSize="18"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10,20,10,10" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Lautstärke:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Slider Style="{StaticResource GreenSliderStyle}" Value="{Binding Volume, Mode=TwoWay}" Minimum="0.0" Maximum="1.0" Width="200"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</UserControl>